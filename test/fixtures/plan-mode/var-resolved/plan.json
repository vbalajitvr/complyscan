{
  "format_version": "1.2",
  "terraform_version": "1.7.5",
  "variables": {
    "log_bucket_name": { "value": "acme-prod-bedrock-logs" },
    "log_group_name": { "value": "/aws/bedrock/invocation-logs" }
  },
  "planned_values": {
    "root_module": {
      "resources": [
        {
          "address": "aws_bedrock_model_invocation_logging_configuration.main",
          "type": "aws_bedrock_model_invocation_logging_configuration",
          "name": "main",
          "values": {
            "logging_config": {
              "embedding_data_delivery_enabled": true,
              "text_data_delivery_enabled": true,
              "s3_config": { "bucket_name": "acme-prod-bedrock-logs" },
              "cloudwatch_config": {
                "log_group_name": "/aws/bedrock/invocation-logs",
                "role_arn": "arn:aws:iam::123456789012:role/bedrock-cw-role"
              }
            }
          }
        },
        {
          "address": "aws_s3_bucket.logs",
          "type": "aws_s3_bucket",
          "name": "logs",
          "values": { "bucket": "acme-prod-bedrock-logs" }
        },
        {
          "address": "aws_cloudwatch_log_group.bedrock",
          "type": "aws_cloudwatch_log_group",
          "name": "bedrock",
          "values": { "name": "/aws/bedrock/invocation-logs", "retention_in_days": 365 }
        }
      ]
    }
  },
  "resource_changes": [
    {
      "address": "aws_bedrock_model_invocation_logging_configuration.main",
      "type": "aws_bedrock_model_invocation_logging_configuration",
      "name": "main",
      "change": { "actions": ["create"] }
    },
    {
      "address": "aws_s3_bucket.logs",
      "type": "aws_s3_bucket",
      "name": "logs",
      "change": { "actions": ["create"] }
    }
  ]
}
