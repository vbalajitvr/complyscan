{
  "name": "infrarails",
  "version": "0.2.0",
  "description": "Static scanner for EU AI Act Article 9 & 12 compliance gaps in Terraform — checks AWS Bedrock guardrails, logging, retention, and traceability against EU AI Act, NIST AI RMF, and ISO/IEC 42001",
  "main": "dist/index.js",
  "bin": {
    "infrarails": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "terraform",
    "compliance",
    "eu-ai-act",
    "scanner"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/policyrails/infrarails.git"
  },
  "bugs": {
    "url": "https://github.com/policyrails/infrarails/issues"
  },
  "homepage": "https://github.com/policyrails/infrarails#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pdfkit": "^0.17.6",
    "tsup": "^8.5.1",
    "typescript": "5.4",
    "vitest": "^4.1.5"
  }
}
